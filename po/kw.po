#: data/com.github.huluti.Curtail.appdata.xml.in:7
#: data/com.github.huluti.Curtail.desktop.in:2 data/ui/window.blp:29
#: data/ui/window.blp:53 data/ui/window.blp:78
msgid "Curtail"
msgstr "Lettya"

#: data/com.github.huluti.Curtail.appdata.xml.in:8
#: data/com.github.huluti.Curtail.desktop.in:4
msgid "Compress your images"
msgstr "Gwaska agas skeusennow"

#: data/com.github.huluti.Curtail.appdata.xml.in:10
msgid ""
"Optimize your images with Curtail, a useful image compressor that supports "
"PNG, JPEG, WebP and SVG file types."
msgstr ""
"Gwaska agas skeusennow gans Curtail, gwaskell skeusen gweresek a skoodh "
"eghennow restren PNG, JPEG, WebP, ha SVG."

#: data/com.github.huluti.Curtail.appdata.xml.in:12
msgid ""
"It supports both lossless and lossy compression modes with an option to "
"whether keep or not metadata of images."
msgstr ""
"Y a skoodh an dhiw fordhow a waskans, ankollek ha kollek, gans dewis mar "
"kwitha metadata a'n skeusennow."

#. Keywords, do not translate
#: data/com.github.huluti.Curtail.desktop.in:15
msgid "compress;optimize;image;photo;"
msgstr "gwaska;aven;skeusen;imach;"

#: data/com.github.huluti.Curtail.gschema.xml:6
msgid "Save into a new file"
msgstr "Sawya yn restren nowydh"

#: data/com.github.huluti.Curtail.gschema.xml:7
msgid "Save the compressed image into a new file."
msgstr "Sawya an restren waskys yn restren nowydh."

#: data/com.github.huluti.Curtail.gschema.xml:11
msgid "Select the mode to append text for a new file"
msgstr "Dewis an fordh dhe ystyn tekst rag restren nowydh"

#: data/com.github.huluti.Curtail.gschema.xml:12
msgid ""
"Set how to append the additional text (as suffix or prefix) for a new file."
msgstr ""
"Gorra fatel yllir ystyn an tekst keworransel (avel lostelven po ragelven) "
"rag restren nowydh."

#: data/com.github.huluti.Curtail.gschema.xml:16
msgid "Enable recursive compression in folders"
msgstr "Bywhe gwaskans dasleverek yn restrenvaow"

#: data/com.github.huluti.Curtail.gschema.xml:17
msgid "This setting enable compression in a recursive way in folders."
msgstr "An settyans ma a vywha gwaskans yn agwedh dhasleverek yn restrenvaow."

#: data/com.github.huluti.Curtail.gschema.xml:21
msgid "Preserve metadata"
msgstr "Gwitha metadata"

#: data/com.github.huluti.Curtail.gschema.xml:22
msgid "This setting preserves metadata of images."
msgstr "An settyans ma a with metadata a skeusennow."

#: data/com.github.huluti.Curtail.gschema.xml:26
msgid "Preserve file permissions and timestamps if possible"
msgstr "Gwitha kumyasow ha termynyow restren mars yw possybyl"

#: data/com.github.huluti.Curtail.gschema.xml:27
msgid "This setting file permissions and timestamps of images if possible."
msgstr ""
"An settyans ma a with kumyasow ha termynyow restren a skeusennow mars yw "
"possybyl."

#: data/com.github.huluti.Curtail.gschema.xml:31
msgid "Enable lossy mode"
msgstr "Bywhe fordh gollek"

#: data/com.github.huluti.Curtail.gschema.xml:32
msgid "Use lossy mode to compress images."
msgstr "Devnydhya fordh gollek rag gwiska skeusen."

#: data/com.github.huluti.Curtail.gschema.xml:36
msgid "Suffix/Prefix to append at new file"
msgstr "Lostelven/Ragelven rag ystyn yn restren nowydh"

#: data/com.github.huluti.Curtail.gschema.xml:37
msgid "Suffix/Prefix to append at new file."
msgstr "Lostelven/Ragelven rag ystyn yn restren nowydh."

#: data/com.github.huluti.Curtail.gschema.xml:41
msgid "PNG Lossy Compression Level"
msgstr "Nivel Gwaskans Kollek PNG"

#: data/com.github.huluti.Curtail.gschema.xml:42
msgid "Lossy compression level to use for PNG images."
msgstr "Nivel gwaskans kollek dhe dhevnydhya gans skeusennow PNG."

#: data/com.github.huluti.Curtail.gschema.xml:46
msgid "PNG Lossless Compression Level"
msgstr "Nivel Gwaskans Ankollek PNG"

#: data/com.github.huluti.Curtail.gschema.xml:47
msgid "Lossless compression level to use for PNG images."
msgstr "Nivel gwaskans ankollek dhe dhevnydhya gans skeusennow PNG."

#: data/com.github.huluti.Curtail.gschema.xml:51
msgid "JPG Lossy Compression Level"
msgstr "Nivel Gwaskans Kollek JPG"

#: data/com.github.huluti.Curtail.gschema.xml:52
msgid "Lossy compression level to use for JPG images."
msgstr "Nivel gwaskans kollek dhe dhevnydhya gans skeusennow JPG."

#: data/com.github.huluti.Curtail.gschema.xml:56
msgid "WebP Lossy Compression Level"
msgstr "Nivel Gwaskans Kollek WebP"

#: data/com.github.huluti.Curtail.gschema.xml:57
msgid "Lossy compression level to use for WebP images."
msgstr "Nivel gwaskans kollek dhe dhevnydhya gans skeusennow WebP."

#: data/com.github.huluti.Curtail.gschema.xml:61
msgid "WebP Lossless Compression Level"
msgstr "Nivel Gwaskans Ankollek WebP"

#: data/com.github.huluti.Curtail.gschema.xml:62
msgid "Lossless compression level to use for WebP images."
msgstr "Nivel gwaskans ankollek dhe dhevnydhya gans skeusennow WebP."

#: data/com.github.huluti.Curtail.gschema.xml:66
msgid "Enable progressive encoding for JPEG images"
msgstr "Bwyhe ow kodenni yn avonsek rag skeusennow JPEG"

#: data/com.github.huluti.Curtail.gschema.xml:67
msgid "Optionally encode jpeg images progressively."
msgstr "Dre dhewis kodenni skeusennnow jpeg yn avonsek."

#: data/com.github.huluti.Curtail.gschema.xml:71
msgid "Enable maximum compression for SVG images"
msgstr "Bywhe gwaskans moyha rag skeusennow SVG"

#: data/com.github.huluti.Curtail.gschema.xml:72
msgid "Enable maximum cleaning of SVG images."
msgstr "Bywhe karth moyha a skeusennow SVG."

#: data/com.github.huluti.Curtail.gschema.xml:76 data/ui/preferences.blp:50
msgid "Compression Timeout"
msgstr "Termyn Yn-mes Gwaskans"

#: data/com.github.huluti.Curtail.gschema.xml:77
msgid "Compression timeout for each image."
msgstr "Termyn yn-mes gwaskans rag pub skeusen."

#: data/ui/preferences.blp:5 data/ui/window.blp:12
msgid "Preferences"
msgstr "Dewisyow"

#: data/ui/preferences.blp:9
msgid "General"
msgstr "Ollgemmyn"

#: data/ui/preferences.blp:14
msgid "Safe Mode"
msgstr "Fordh Saw"

#: data/ui/preferences.blp:15
msgid "Save the compressed image in a new file"
msgstr "Sawya an skeusen waskys yn restren nowydh"

#: data/ui/preferences.blp:19
msgid "Naming Mode"
msgstr "Fordh Henwyn"

#: data/ui/preferences.blp:20
msgid "Select between suffix and prefix"
msgstr "Dewis yntra lostelven ha ragelven"

#: data/ui/preferences.blp:24
msgid "Suffix"
msgstr "Lostelven"

#: data/ui/preferences.blp:25
msgid "Prefix"
msgstr "Ragelven"

#: data/ui/preferences.blp:31
msgid "New File Suffix/Prefix"
msgstr "Restren Nowydh Lostelven/Ragelven"

#: data/ui/preferences.blp:35
msgid "Recursive Compression"
msgstr "Gwaskans Dasleverek"

#: data/ui/preferences.blp:36
msgid "Enable or disable compression through subdirectories"
msgstr "Byw po marowhe gwaskans dres isrestrenvaow"

#: data/ui/preferences.blp:40
msgid "Keep Metadata"
msgstr "Gwitha Metadata"

#: data/ui/preferences.blp:41
msgid "Keep metadata chunks that do not affect rendering"
msgstr "Gwitha darnow metadata may ny venni rendrans"

#: data/ui/preferences.blp:45
msgid "Keep File Attributes When Possible"
msgstr "Gwitha Teythiennow Restren Mars Yw Possybyl"

#: data/ui/preferences.blp:46
msgid ""
"Ensure the new file has the same permissions and timestamps as the original "
"file"
msgstr ""
"Surhe yma dhe'n restren nowydh an gumyasow ha termynyow geth dell an restren "
"wreydhek"

#: data/ui/preferences.blp:51
msgid "Set the timeout between images"
msgstr "Gorra an termyn yn-mes yntra skeusennow"

#: data/ui/preferences.blp:65
msgid "Formats"
msgstr "Furvasow"

#: data/ui/preferences.blp:72 data/ui/preferences.blp:98
#: data/ui/preferences.blp:118
msgid "Lossy Compression"
msgstr "Gwaskans Kollek"

#: data/ui/preferences.blp:73 data/ui/preferences.blp:99
#: data/ui/preferences.blp:119
msgid "Set the quality of the generated image, 100 is the best quality"
msgstr "Gorra an kwalita a'n skeusen dhinythys, 100 yw an gwella kwalita"

#: data/ui/preferences.blp:83 data/ui/preferences.blp:129
msgid "Lossless Compression"
msgstr "Gwaskans Ankollek"

#: data/ui/preferences.blp:84 data/ui/preferences.blp:130
msgid "Set the level of compression, 6 is the highest but slowest level"
msgstr "Gorra an nivel a'n gwaskans, 6 yw an ughella mes syger"

#: data/ui/preferences.blp:109
msgid "Progressive Encode"
msgstr "Kodenni Avonsek"

#: data/ui/preferences.blp:110
msgid "Enable incremental image rendering, going from blurry to clear"
msgstr "Bywhe rendrans skeusen avonsek, ow mos dhyworth ankler dhe gler"

#: data/ui/preferences.blp:144
msgid "Maximum Compression Level"
msgstr "Nivel Gwaskans Moyha"

#: data/ui/preferences.blp:145
msgid "This can be more destructive for the image"
msgstr "Hemma a yll bos moy distruyansek rag an skeusen"

#: data/ui/result-item-row.blp:8 data/ui/result-item-row.blp:34
msgid "More Information"
msgstr "Moy Kedhlow"

#: data/ui/result-item-row.blp:18
msgid ""
"Compression was skipped because compressing the file would have resulted in "
"a larger file size."
msgstr ""
"Gwaskans o skyppys drefen ow kwaska an restren y fia sewys yn braster "
"restren vrassa."

